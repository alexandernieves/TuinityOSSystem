  invoiceTotal             Decimal   @map("invoice_total") @db.Decimal(12, 2)
  commissionableAmount     Decimal   @map("commissionable_amount") @db.Decimal(12, 2)
  nonCommissionableAmount  Decimal   @map("non_commissionable_amount") @db.Decimal(12, 2)
  paidAmount               Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  commissionEligibleAmount Decimal   @default(0) @map("commission_eligible_amount") @db.Decimal(12, 2)
  commissionPendingAmount  Decimal   @map("commission_pending_amount") @db.Decimal(12, 2)
  commissionRate           Decimal?  @map("commission_rate") @db.Decimal(5, 2)
  collectionStatus         String    @default("PENDING") @map("collection_status")
  commissionStatus         String    @default("PENDING_COLLECTION") @map("commission_status")
  periodMonth              Int?      @map("period_month")
  periodYear               Int?      @map("period_year")
  liquidatedAt             DateTime? @map("liquidated_at") @db.Timestamptz(6)
  liquidatedByUserId       String?   @map("liquidated_by_user_id") @db.Uuid
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  notes                    String?
  customer                 Customer  @relation("CommissionCustomer", fields: [customerId], references: [id])
  invoice                  Invoice   @relation("CommissionInvoice", fields: [invoiceId], references: [id])
  liquidatedBy             User?     @relation("CommissionLiquidator", fields: [liquidatedByUserId], references: [id])
  seller                   User      @relation("CommissionSeller", fields: [sellerUserId], references: [id])

  @@index([sellerUserId])
  @@index([invoiceId])
  @@index([customerId])
  @@index([collectionStatus])
  @@index([commissionStatus])
  @@map("commission_records")
}

