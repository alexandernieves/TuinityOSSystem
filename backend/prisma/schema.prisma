generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                               String                    @id @default(uuid()) @db.Uuid
  email                            String                    @unique
  passwordHash                     String                    @map("password_hash")
  name                             String?
  isActive                         Boolean                   @default(false) @map("is_active")
  lastLoginAt                      DateTime?                 @map("last_login_at") @db.Timestamptz(6)
  createdAt                        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  avatar                           String?
  status                           UserStatus                @default(PENDING)
  createdAccountsPayableEntries    AccountsPayableEntry[]
  createdAccountsReceivableEntries AccountsReceivableEntry[]
  approvalDecisions                ApprovalDecision[]
  assignedApprovalRequests         ApprovalRequest[]         @relation("UserAssignedApprovals")
  requestedApprovalRequests        ApprovalRequest[]         @relation("UserRequestedApprovals")
  uploadedAttachments              Attachment[]
  auditLogs                        AuditLog[]
  bls                              BillOfLading[]
  cashRegisters                    CashRegister[]
  commissionRecordsAsLiquidator    CommissionRecord[]        @relation("CommissionLiquidator")
  commissionRecordsAsSeller        CommissionRecord[]        @relation("CommissionSeller")
  assignedCustomers                Customer[]
  dmcs                             DMC[]
  expedients                       Expedient[]
  approvedAdjustments              InventoryAdjustment[]     @relation("UserApprovedAdjustments")
  createdAdjustments               InventoryAdjustment[]     @relation("UserCreatedAdjustments")
  createdInventoryMovements        InventoryMovement[]
  createdTransfers                 InventoryTransfer[]       @relation("UserCreatedTransfers")
  receivedTransfers                InventoryTransfer[]       @relation("UserReceivedTransfers")
  createdInvoices                  Invoice[]
  createdJournalEntries            JournalEntry[]            @relation("UserCreatedJournalEntries")
  postedJournalEntries             JournalEntry[]            @relation("UserPostedJournalEntries")
  notificationPreferences          NotificationPreference[]
  notifications                    Notification[]
  posSales                         POSSale[]
  createdPurchaseOrders            PurchaseOrder[]
  createdPurchaseReceipts          PurchaseReceipt[]
  createdQuotations                Quotation[]
  createdReceipts                  Receipt[]
  createdSalesOrders               SalesOrder[]
  sessions                         Session[]
  userRoles                        UserRole[]
  createdVendorPayments            VendorPayment[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  loginAt      DateTime @map("login_at") @db.Timestamptz(6)
  lastActivity DateTime @map("last_activity") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("sessions")
}

model Expedient {
  id                 String              @id @default(uuid()) @db.Uuid
  reference          String              @unique
  type               String
  status             String              @default("pendiente")
  priority           String              @default("normal")
  sourceDocumentId   String              @map("source_document_id")
  sourceDocumentType String              @map("source_document_type")
  counterpartName    String              @map("counterpart_name")
  counterpartCountry String?             @map("counterpart_country")
  totals             Json?
  transport          Json?
  notes              String?
  createdByUserId    String?             @map("created_by_user_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  bls                BillOfLading[]
  dmcs               DMC[]
  timeline           ExpedientTimeline[]
  createdByUser      User?               @relation(fields: [createdByUserId], references: [id])

  @@index([reference])
  @@index([status])
  @@map("expedients")
}

model DMC {
  id                  String    @id @default(uuid()) @db.Uuid
  reference           String    @unique
  expedientId         String    @map("expedient_id") @db.Uuid
  type                String
  status              String    @default("borrador")
  shipperName         String    @map("shipper_name")
  consigneeName       String    @map("consignee_name")
  consigneeCountry    String    @map("consignee_country")
  merchandiseLines    Json?     @map("merchandise_lines")
  totals              Json?
  governmentDMCNumber String?   @map("government_dmc_number")
  createdByUserId     String?   @map("created_by_user_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdByUser       User?     @relation(fields: [createdByUserId], references: [id])
  expedient           Expedient @relation(fields: [expedientId], references: [id], onDelete: Cascade)

  @@index([reference])
  @@index([expedientId])
  @@map("dmcs")
}

model BillOfLading {
  id              String    @id @default(uuid()) @db.Uuid
  reference       String    @unique
  expedientId     String    @map("expedient_id") @db.Uuid
  status          String    @default("borrador")
  shipperName     String    @map("shipper_name")
  consigneeName   String    @map("consignee_name")
  vesselName      String    @map("vessel_name")
  portOfLoading   String    @map("port_of_loading")
  portOfDischarge String    @map("port_of_discharge")
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdByUser   User?     @relation(fields: [createdByUserId], references: [id])
  expedient       Expedient @relation(fields: [expedientId], references: [id], onDelete: Cascade)

  @@index([reference])
  @@index([expedientId])
  @@map("bills_of_lading")
}

model ExpedientTimeline {
  id          String    @id @default(uuid()) @db.Uuid
  expedientId String    @map("expedient_id") @db.Uuid
  action      String
  description String?
  metadata    Json?
  userId      String?   @map("user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expedient   Expedient @relation(fields: [expedientId], references: [id], onDelete: Cascade)

  @@index([expedientId])
  @@map("expedient_timeline")
}

model CommercialParams {
  id                  String   @id @default(uuid()) @db.Uuid
  priceLevels         Json?    @map("price_levels")
  defaultPriceLevel   String   @default("C") @map("default_price_level")
  commissionThreshold Decimal? @map("commission_threshold") @db.Decimal(10, 2)
  commissionRates     Json?    @map("commission_rates")
  taxRate             Decimal  @default(7) @map("tax_rate") @db.Decimal(5, 2)
  taxExemptZones      Json?    @map("tax_exempt_zones")
  paymentTermsOptions Json?    @map("payment_terms_options")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  notes               String?
  taxConfig           Json?    @map("tax_config")

  @@map("commercial_params")
}

model DocumentNumbering {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique
  documentLabel String   @map("document_label")
  prefix        String?  @default("")
  currentNumber Int      @default(1) @map("current_number")
  paddingLength Int      @default(5) @map("padding_length")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([code])
  @@map("document_numbering")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address") @db.Inet
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Brand {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique
  code      String?   @unique
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  products  Product[]

  @@map("brands")
}

model ProductGroup {
  id          String            @id @default(uuid()) @db.Uuid
  name        String            @unique
  nameEnglish String?           @map("name_english")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  subgroups   ProductSubgroup[]
  products    Product[]

  @@map("product_groups")
}

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  parentId    String?    @map("parent_id") @db.Uuid
  level       Int        @default(1)
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent      Category?  @relation("ParentChildren", fields: [parentId], references: [id])
  children    Category[] @relation("ParentChildren")
  products    Product[]  @relation("ProductCategory")
  subproducts Product[]  @relation("ProductSubcategory")

  @@map("categories")
}

model ProductSubgroup {
  id          String       @id @default(uuid()) @db.Uuid
  groupId     String       @map("group_id") @db.Uuid
  name        String
  nameEnglish String?      @map("name_english")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  group       ProductGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([groupId, name])
  @@map("product_subgroups")
}

model TariffCode {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  products    Product[]

  @@map("tariff_codes")
}

model Warehouse {
  id                 String                 @id @default(uuid()) @db.Uuid
  name               String                 @unique
  code               String                 @unique
  type               WarehouseType          @default(B2B)
  isActive           Boolean                @default(true) @map("is_active")
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  address            String?
  city               String?
  country            String?
  isHeadquarters     Boolean                @default(false) @map("is_headquarters")
  manager            String?
  phone              String?
  adjustments        InventoryAdjustment[]
  existences         InventoryExistence[]
  inventoryMovements InventoryMovement[]
  reservations       InventoryReservation[]
  destTransfers      InventoryTransfer[]    @relation("DestWarehouseTransfers")
  sourceTransfers    InventoryTransfer[]    @relation("SourceWarehouseTransfers")
  possaleLines       POSSaleLine[]
  productLots        ProductLot[]
  purchaseOrders     PurchaseOrder[]
  purchaseReceipts   PurchaseReceipt[]
  quotations         Quotation[]
  salesOrders        SalesOrder[]

  @@map("warehouses")
}

model Product {
  id                   String                    @id @default(uuid()) @db.Uuid
  sku                  String                    @unique
  name                 String
  description          String?
  brandId              String?                   @map("brand_id") @db.Uuid
  groupId              String                    @map("group_id") @db.Uuid
  subgroupId           String?                   @map("subgroup_id") @db.Uuid
  tariffCodeId         String?                   @map("tariff_code_id") @db.Uuid
  countryOfOrigin      String?                   @map("country_of_origin")
  unitsPerBox          Int?                      @map("units_per_box")
  unitsPerPallet       Int?                      @map("units_per_pallet")
  weightPerPackage     Decimal?                  @map("weight_per_package") @db.Decimal(10, 3)
  volumeM3             Decimal?                  @map("volume_m3") @db.Decimal(10, 3)
  volumeFt3            Decimal?                  @map("volume_ft3") @db.Decimal(10, 3)
  standardCost         Decimal?                  @map("standard_cost") @db.Decimal(12, 2)
  minimumQuantity      Int?                      @map("minimum_quantity")
  isActive             Boolean                   @default(true) @map("is_active")
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  categoryId           String?                   @map("category_id") @db.Uuid
  costAvgWeighted      Decimal?                  @map("cost_avg_weighted") @db.Decimal(12, 2)
  costCIF              Decimal?                  @map("cost_cif") @db.Decimal(12, 2)
  costFOB              Decimal?                  @map("cost_fob") @db.Decimal(12, 2)
  image                String?
  requiresLot          Boolean                   @default(false) @map("requires_lot")
  subcategoryId        String?                   @map("subcategory_id") @db.Uuid
  adjustmentLines      InventoryAdjustmentLine[]
  existences           InventoryExistence[]
  inventoryMovements   InventoryMovement[]
  reservations         InventoryReservation[]
  transferLines        InventoryTransferLine[]
  invoiceLines         InvoiceLine[]
  packingListLines     PackingListLine[]
  possaleLines         POSSaleLine[]
  barcodes             ProductBarcode[]
  productLots          ProductLot[]
  prices               ProductPrice[]
  brand                Brand?                    @relation(fields: [brandId], references: [id])
  category             Category?                 @relation("ProductCategory", fields: [categoryId], references: [id])
  group                ProductGroup              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subcategory          Category?                 @relation("ProductSubcategory", fields: [subcategoryId], references: [id])
  subgroup             ProductSubgroup?          @relation(fields: [subgroupId], references: [id])
  tariffCode           TariffCode?               @relation(fields: [tariffCodeId], references: [id])
  purchaseOrderLines   PurchaseOrderLine[]
  purchaseReceiptLines PurchaseReceiptLine[]
  quotationLines       QuotationLine[]
  salesOrderLines      SalesOrderLine[]

  @@index([sku])
  @@index([brandId])
  @@index([groupId])
  @@index([subgroupId])
  @@index([tariffCodeId])
  @@index([isActive])
  @@map("products")
}

model InventoryExistence {
  id          String    @id @default(uuid()) @db.Uuid
  productId   String    @map("product_id") @db.Uuid
  warehouseId String    @map("warehouse_id") @db.Uuid
  existence   Decimal   @default(0) @db.Decimal(12, 2)
  arriving    Decimal   @default(0) @db.Decimal(12, 2)
  reserved    Decimal   @default(0) @db.Decimal(12, 2)
  available   Decimal   @default(0) @db.Decimal(12, 2)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory_existence")
}

model ProductBarcode {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  barcode   String   @unique
  type      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_barcodes")
}

model ProductPrice {
  id        String     @id @default(uuid()) @db.Uuid
  productId String     @map("product_id") @db.Uuid
  level     PriceLevel
  price     Decimal    @db.Decimal(12, 2)
  currency  String     @default("USD")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, level])
  @@index([productId])
  @@index([level])
  @@map("product_prices")
}

model Customer {
  id                        String                    @id @default(uuid()) @db.Uuid
  code                      String                    @unique
  legalName                 String                    @map("legal_name")
  tradeName                 String?                   @map("trade_name")
  taxId                     String?                   @map("tax_id")
  email                     String?
  phone                     String?
  country                   String?                   @default("PA")
  assignedSalesUserId       String?                   @map("assigned_sales_user_id") @db.Uuid
  isActive                  Boolean                   @default(true) @map("is_active")
  createdAt                 DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  mobile                    String?
  taxDv                     String?                   @map("tax_dv")
  accountsReceivableEntries AccountsReceivableEntry[]
  commissionRecords         CommissionRecord[]        @relation("CommissionCustomer")
  addresses                 CustomerAddress[]
  contacts                  CustomerContact[]
  creditProfile             CustomerCreditProfile?
  assignedSalesUser         User?                     @relation(fields: [assignedSalesUserId], references: [id])
  invoices                  Invoice[]
  possales                  POSSale[]
  quotations                Quotation[]
  receipts                  Receipt[]
  salesOrders               SalesOrder[]

  @@index([code])
  @@index([taxId])
  @@index([assignedSalesUserId])
  @@index([isActive])
  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  name       String
  email      String?
  phone      String?
  position   String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([isPrimary])
  @@map("customer_contacts")
}

model CustomerAddress {
  id           String   @id @default(uuid()) @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  label        String?
  addressLine1 String   @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  city         String?
  state        String?
  country      String?
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([isPrimary])
  @@map("customer_addresses")
}

model CustomerCreditProfile {
  id                          String     @id @default(uuid()) @db.Uuid
  customerId                  String     @unique @map("customer_id") @db.Uuid
  creditLimit                 Decimal    @map("credit_limit") @db.Decimal(12, 2)
  creditDays                  Int?       @map("credit_days")
  currentBalance              Decimal    @default(0) @map("current_balance") @db.Decimal(12, 2)
  priceLevel                  PriceLevel @map("price_level")
  isCreditBlocked             Boolean    @default(false) @map("is_credit_blocked")
  requiresApprovalOnOverlimit Boolean    @default(true) @map("requires_approval_on_overlimit")
  createdAt                   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer                    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_credit_profiles")
}

model Supplier {
  id                     String                 @id @default(uuid()) @db.Uuid
  code                   String                 @unique
  legalName              String                 @map("legal_name")
  tradeName              String?                @map("trade_name")
  taxId                  String?                @map("tax_id")
  email                  String?
  phone                  String?
  country                String?                @default("PA")
  isActive               Boolean                @default(true) @map("is_active")
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  address                String?
  city                   String?
  currentBalance         Decimal                @default(0) @map("current_balance") @db.Decimal(12, 2)
  notes                  String?
  paymentTerms           Int?                   @default(0) @map("payment_terms")
  taxDv                  String?                @map("tax_dv")
  type                   String?                @default("MERCHANDISE")
  accountsPayableEntries AccountsPayableEntry[]
  purchaseOrders         PurchaseOrder[]
  purchaseReceipts       PurchaseReceipt[]
  contacts               SupplierContact[]
  vendorPayments         VendorPayment[]

  @@index([code])
  @@index([taxId])
  @@index([isActive])
  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(uuid()) @db.Uuid
  supplierId String   @map("supplier_id") @db.Uuid
  name       String
  email      String?
  phone      String?
  position   String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
