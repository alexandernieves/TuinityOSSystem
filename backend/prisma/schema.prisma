  receivedByUserId  String?                 @map("received_by_user_id") @db.Uuid
  receivedAt        DateTime?               @map("received_at")
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  lines             InventoryTransferLine[]
  createdByUser     User?                   @relation("UserCreatedTransfers", fields: [createdByUserId], references: [id])
  destWarehouse     Warehouse               @relation("DestWarehouseTransfers", fields: [destWarehouseId], references: [id])
  receivedByUser    User?                   @relation("UserReceivedTransfers", fields: [receivedByUserId], references: [id])
  sourceWarehouse   Warehouse               @relation("SourceWarehouseTransfers", fields: [sourceWarehouseId], references: [id])

  @@index([reference])
  @@index([sourceWarehouseId])
  @@index([destWarehouseId])
  @@index([status])
  @@map("inventory_transfers")
}

model InventoryTransferLine {
  id               String            @id @default(uuid()) @db.Uuid
  transferId       String            @map("transfer_id") @db.Uuid
  productId        String            @map("product_id") @db.Uuid
  quantity         Decimal           @db.Decimal(12, 2)
  receivedQty      Decimal?          @map("received_qty") @db.Decimal(12, 2)
  hasDiscrepancy   Boolean           @default(false) @map("has_discrepancy")
  discrepancyNotes String?           @map("discrepancy_notes")
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  transfer         InventoryTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([productId])
  @@map("inventory_transfer_lines")
}

model ReceiptApplication {
  id            String   @id @default(uuid()) @db.Uuid
  receiptId     String   @map("receipt_id") @db.Uuid
  invoiceId     String   @map("invoice_id") @db.Uuid
  appliedAmount Decimal  @map("applied_amount") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receipt       Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@unique([receiptId, invoiceId])
  @@index([receiptId])
  @@index([invoiceId])
  @@map("receipt_applications")
}

model AccountsReceivableEntry {
  id              String                      @id @default(uuid()) @db.Uuid
  customerId      String                      @map("customer_id") @db.Uuid
  invoiceId       String?                     @map("invoice_id") @db.Uuid
  receiptId       String?                     @map("receipt_id") @db.Uuid
  entryType       AccountsReceivableEntryType
  amount          Decimal                     @db.Decimal(12, 2)
  balanceAfter    Decimal?                    @map("balance_after") @db.Decimal(12, 2)
  occurredAt      DateTime                    @map("occurred_at") @db.Timestamptz(6)
  notes           String?
  createdByUserId String?                     @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdByUser   User?                       @relation(fields: [createdByUserId], references: [id])
  customer        Customer                    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice         Invoice?                    @relation(fields: [invoiceId], references: [id])
  receipt         Receipt?                    @relation(fields: [receiptId], references: [id])

  @@index([customerId])
  @@index([invoiceId])
  @@index([receiptId])
  @@index([entryType])
  @@index([occurredAt])
  @@map("accounts_receivable_entries")
}

model ApprovalRequest {
  id                String                @id @default(uuid()) @db.Uuid
  type              ApprovalRequestType
  referenceType     String?               @map("reference_type")
  referenceId       String?               @map("reference_id")
  requestedByUserId String                @map("requested_by_user_id") @db.Uuid
  assignedToUserId  String?               @map("assigned_to_user_id") @db.Uuid
  status            ApprovalRequestStatus
  reason            String?
  requestedAt       DateTime              @map("requested_at") @db.Timestamptz(6)
  resolvedAt        DateTime?             @map("resolved_at") @db.Timestamptz(6)
  notes             String?
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  decisions         ApprovalDecision[]
  assignedToUser    User?                 @relation("UserAssignedApprovals", fields: [assignedToUserId], references: [id])
  requestedByUser   User                  @relation("UserRequestedApprovals", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([referenceType, referenceId])
  @@index([requestedByUserId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([requestedAt])
  @@map("approval_requests")
}

model ApprovalDecision {
  id                String               @id @default(uuid()) @db.Uuid
  approvalRequestId String               @map("approval_request_id") @db.Uuid
  decidedByUserId   String               @map("decided_by_user_id") @db.Uuid
  decision          ApprovalDecisionType
  reason            String?
  decidedAt         DateTime             @map("decided_at") @db.Timestamptz(6)
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvalRequest   ApprovalRequest      @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  decidedByUser     User                 @relation(fields: [decidedByUserId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
  @@index([decidedByUserId])
  @@index([decision])
  @@index([decidedAt])
  @@map("approval_decisions")
}

model CashRegister {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  userName       String    @map("user_name")
  status         String    @default("abierta")
  openingAmount  Decimal   @map("opening_amount") @db.Decimal(12, 2)
  closingAmount  Decimal?  @map("closing_amount") @db.Decimal(12, 2)
  expectedAmount Decimal?  @map("expected_amount") @db.Decimal(12, 2)
  difference     Decimal?  @db.Decimal(12, 2)
  openedAt       DateTime  @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt       DateTime? @map("closed_at") @db.Timestamptz(6)
  cashSales      Decimal   @default(0) @map("cash_sales") @db.Decimal(12, 2)
  cardSales      Decimal   @default(0) @map("card_sales") @db.Decimal(12, 2)
  transferSales  Decimal   @default(0) @map("transfer_sales") @db.Decimal(12, 2)
  totalSales     Decimal   @default(0) @map("total_sales") @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("cash_registers")
}

model Account {
  id                String             @id @default(uuid()) @db.Uuid
  code              String             @unique
  name              String
  type              AccountType
  parentAccountId   String?            @map("parent_account_id") @db.Uuid
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  parentAccount     Account?           @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts     Account[]          @relation("AccountHierarchy")
  journalEntryLines JournalEntryLine[]

  @@index([code])
  @@index([type])
  @@index([parentAccountId])
  @@index([isActive])
  @@map("accounts")
}

model JournalEntry {
  id              String             @id @default(uuid()) @db.Uuid
  number          String             @unique
  entryDate       DateTime           @map("entry_date") @db.Timestamptz(6)
  status          JournalEntryStatus
  referenceType   String?            @map("reference_type")
  referenceId     String?            @map("reference_id")
  memo            String?
  createdByUserId String?            @map("created_by_user_id") @db.Uuid
  postedByUserId  String?            @map("posted_by_user_id") @db.Uuid
  postedAt        DateTime?          @map("posted_at") @db.Timestamptz(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdByUser   User?              @relation("UserCreatedJournalEntries", fields: [createdByUserId], references: [id])
  postedByUser    User?              @relation("UserPostedJournalEntries", fields: [postedByUserId], references: [id])
  lines           JournalEntryLine[]

  @@index([number])
  @@index([entryDate])
  @@index([status])
  @@index([referenceType, referenceId])
  @@index([createdByUserId])
  @@index([postedByUserId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(uuid()) @db.Uuid
  journalEntryId String       @map("journal_entry_id") @db.Uuid
  accountId      String       @map("account_id") @db.Uuid
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  memo           String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([debit])
  @@index([credit])
  @@map("journal_entry_lines")
}

model Attachment {
  id               String   @id @default(uuid()) @db.Uuid
  entityType       String   @map("entity_type")
  entityId         String   @map("entity_id")
  fileName         String   @map("file_name")
  originalName     String?  @map("original_name")
  mimeType         String?  @map("mime_type")
  fileSize         Int?     @map("file_size")
  storageKey       String   @map("storage_key")
  storageBucket    String?  @map("storage_bucket")
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.Uuid
  uploadedAt       DateTime @map("uploaded_at") @db.Timestamptz(6)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  uploadedByUser   User?    @relation(fields: [uploadedByUserId], references: [id])

  @@index([entityType, entityId])
  @@index([uploadedByUserId])
  @@index([uploadedAt])
  @@index([fileName])
  @@map("attachments")
}

