generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum InvoiceStatus {
  ISSUED
  VOID
}

enum InvoiceLineDiscountType {
  NONE
  PERCENT
  AMOUNT
}

model Tenant {
  id        String        @id @default(uuid())
  name      String
  slug      String        @unique
  status    TenantStatus  @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  users     User[]
  roles     Role[]
  branches  Branch[]
  auditLogs AuditLog[]

  @@index([slug])
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceSequences InvoiceSequence[]
  invoices         Invoice[]
  cashRegisters    CashRegister[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum UserRoleType {
  CLIENT
  MEMBER
  ADMIN
  OWNER
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  email        String
  name         String?
  passwordHash String
  status       UserStatus @default(ACTIVE)
  role         UserRoleType @default(CLIENT)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles    UserRole[]
  sessions     Session[]
  auditLogs    AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id        String   @id @default(uuid())
  key       String   @unique
  createdAt DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([key])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId])
}

model InvoiceSequence {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  prefix    String
  lastNumber Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId])
  @@index([tenantId])
  @@index([branchId])
}

model Invoice {
  id              String        @id @default(uuid())
  tenantId        String
  branchId        String
  issuedByUserId  String?
  status          InvoiceStatus @default(ISSUED)
  invoiceNumber   String
  sequenceNumber  Int

  currency        String        @default("USD")
  
  customerName    String
  customerTaxId   String?
  customerPhone   String?

  subtotal        Decimal       @db.Decimal(18, 2)
  discountTotal   Decimal       @db.Decimal(18, 2)
  taxTotal        Decimal       @db.Decimal(18, 2)
  total           Decimal       @db.Decimal(18, 2)

  issuedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  lines           InvoiceLine[]
  payments         Payment[]
  returns          Return[]

  @@unique([tenantId, branchId, invoiceNumber])
  @@index([tenantId, branchId, issuedAt])
  @@index([tenantId, invoiceNumber])
}

model InvoiceLine {
  id            String                 @id @default(uuid())
  tenantId      String
  invoiceId     String

  description   String
  quantity      Decimal                @db.Decimal(18, 4)
  unitPrice     Decimal                @db.Decimal(18, 2)

  discountType  InvoiceLineDiscountType @default(NONE)
  discountValue Decimal                @db.Decimal(18, 4) @default(0)

  taxable       Boolean                @default(true)
  taxRate       Decimal                @db.Decimal(6, 4) @default(0.07)

  lineSubtotal  Decimal                @db.Decimal(18, 2)
  lineDiscount  Decimal                @db.Decimal(18, 2)
  lineTax       Decimal                @db.Decimal(18, 2)
  lineTotal     Decimal                @db.Decimal(18, 2)

  createdAt     DateTime               @default(now())

  invoice       Invoice                @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
}

model Payment {
  id        String      @id @default(uuid())
  tenantId  String
  invoiceId String
  amount    Decimal     @db.Decimal(18, 2)
  method    String      // Efectivo, Tarjeta, Transferencia
  status    String      @default("PENDING") // PENDING, COMPLETED, FAILED
  metadata  Json?       // For card details, bank info, etc.
  paidAt    DateTime?
  createdAt DateTime    @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([status])
}

model Return {
  id           String   @id @default(uuid())
  tenantId     String
  invoiceId    String
  returnNumber String
  amount       Decimal  @db.Decimal(18, 2)
  reason       String
  status       String   @default("PENDING") // PENDING, PROCESSED, CANCELLED
  metadata     Json?    // Additional return details
  createdAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([invoiceId])
  @@index([status])
}

model CashRegister {
  id          String   @id @default(uuid())
  tenantId    String
  branchId    String
  registerId  String   // Caja 01, Caja 02, etc.
  openedBy    String?
  closedBy    String?
  openingDate DateTime @default(now())
  closingDate DateTime?
  openingAmount Decimal @db.Decimal(18, 2) @default(0)
  closingAmount Decimal @db.Decimal(18, 2) @default(0)
  cashSales   Decimal  @db.Decimal(18, 2) @default(0)
  cardSales   Decimal  @db.Decimal(18, 2) @default(0)
  transferSales Decimal @db.Decimal(18, 2) @default(0)
  status      String   @default("OPEN") // OPEN, CLOSED
  metadata    Json?    // Details about discrepancies, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, registerId, openingDate])
  @@index([tenantId])
  @@index([branchId])
  @@index([status])
}

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  sku         String   @unique
  name        String
  description String?
  category    String
  price       Decimal  @db.Decimal(18, 2)
  cost        Decimal  @db.Decimal(18, 2)
  stock       Int      @default(0)
  minStock    Int      @default(5)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([category])
  @@index([isActive])
}

model SalesAnalytics {
  id            String   @id @default(uuid())
  tenantId      String
  branchId      String?
  productId     String?
  date          DateTime
  period        String   // daily, weekly, monthly
  totalSales    Decimal  @db.Decimal(18, 2)
  totalUnits    Int
  totalInvoices Int
  avgTicket     Decimal  @db.Decimal(18, 2)
  metadata      Json?    // Additional analytics data
  createdAt     DateTime @default(now())

  @@unique([tenantId, branchId, productId, date, period])
  @@index([tenantId])
  @@index([branchId])
  @@index([productId])
  @@index([date])
  @@index([period])
}
